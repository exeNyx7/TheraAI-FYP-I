		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Signup - Create Test User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    pm.collectionVariables.set('user_id', pm.response.json().id);",
									"    pm.test('User created successfully', () => {",
									"        pm.expect(pm.response.code).to.equal(201);",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"journal_test@theraai.com\",\n  \"password\": \"TestPass123\",\n  \"confirm_password\": \"TestPass123\",\n  \"full_name\": \"Journal Test User\",\n  \"role\": \"patient\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/signup",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "signup"]
						},
						"description": "Create a test user for journal testing"
					},
					"response": []
				},
				{
					"name": "Login - Get Auth Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.collectionVariables.set('auth_token', response.access_token);",
									"    pm.collectionVariables.set('user_id', response.user.id);",
									"    pm.test('Login successful', () => {",
									"        pm.expect(response.access_token).to.be.a('string');",
									"        pm.expect(response.token_type).to.equal('bearer');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"journal_test@theraai.com\",\n  \"password\": \"TestPass123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "login"]
						},
						"description": "Login and get JWT token (automatically saved to collection variables)"
					},
					"response": []
				}
			],
			"description": "Authentication endpoints (prerequisite for journal access)"
