# ══════════════════════════════════════════════════════════════════════════════
# TheraAI — Environment Variables Example
# Copy this file to .env and fill in real values before starting the app.
#
# DO NOT commit .env to version control — it contains secrets.
# This file (.env.example) IS safe to commit — it has no real values.
# ══════════════════════════════════════════════════════════════════════════════


# ── Backend (backend/.env) ────────────────────────────────────────────────────

# REQUIRED: Secret key for JWT token signing (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-change-this-in-production

# REQUIRED: MongoDB connection string
MONGODB_URL=mongodb://localhost:27017
# For Docker: mongodb://admin:password@mongodb:27017/theraai?authSource=admin

# REQUIRED: Database name
MONGODB_DATABASE=theraai_dev

# Optional: Separate test database (used by pytest when running tests)
MONGODB_TEST_DATABASE=theraai_test

# Application mode (development enables /docs and /redoc endpoints)
DEBUG=True
ENVIRONMENT=development

# JWT token expiry settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (optional — for rate limiting and session caching)
REDIS_URL=redis://localhost:6379
# For Docker: redis://redis:6379/0

# CORS: Allowed frontend origins (comma-separated in production)
CORS_ORIGINS=["http://localhost:3000"]

# Ollama settings (for AI chat — run `ollama pull llama3.1:8b` first)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Optional: OpenAI API key (reserved for future integration)
OPENAI_API_KEY=

# ── Email Notifications (Phase 5 — fastapi-mail) ────────────────────────────
# Set MAIL_ENABLED=True in production to activate email sending
MAIL_ENABLED=False
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@theraai.app
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
# Admin email receives crisis alerts when no therapist is assigned
ADMIN_EMAIL=admin@theraai.app


# ── Frontend (web/.env) ───────────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:8000

# App name (shown in browser tab and UI)
VITE_APP_NAME=TheraAI

# Environment label
VITE_ENVIRONMENT=development

# localStorage key for storing the JWT auth token
VITE_AUTH_TOKEN_KEY=theraai_auth_token

# Enable debug mode in frontend
VITE_DEBUG_MODE=true


# ── Docker Compose (docker/.env or .env.docker) ───────────────────────────────

# Used when running with docker-compose up
# MONGODB_URL=mongodb://admin:password@mongodb:27017/theraai?authSource=admin
# REDIS_URL=redis://redis:6379/0
# DEBUG=True
# SECRET_KEY=your-secret-key-here
# VITE_API_URL=http://localhost:8000/api/v1
