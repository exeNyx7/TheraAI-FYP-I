# =============================================================================
# TheraAI Backend — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# Variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] have defaults and can be left empty.
#
# SETUP GUIDES FOR EACH SERVICE:
#   Google Calendar  → see section "Google OAuth (Calendar Sync)"
#   Firebase / FCM   → see section "Firebase Cloud Messaging"
#   Gmail SMTP       → see section "Email / SMTP"
# =============================================================================

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=TheraAI Backend
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development   # development | production

# =============================================================================
# Server Configuration
# =============================================================================
HOST=0.0.0.0
PORT=8000
RELOAD=True

# =============================================================================
# Database [REQUIRED]
# =============================================================================
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=theraai_dev
MONGODB_TEST_DATABASE=theraai_test

# For Docker (override at runtime via docker-compose):
# MONGODB_URL=mongodb://admin:password123@mongodb:27017/theraai?authSource=admin

# =============================================================================
# Security & Authentication [REQUIRED]
# Generate a strong secret:  python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================
SECRET_KEY=REPLACE_ME_WITH_A_64_CHAR_RANDOM_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000", "http://localhost:5173"]
CORS_ALLOW_CREDENTIALS=True

# =============================================================================
# AI / ML
# Leave OPENAI_API_KEY empty to use local Ollama (llama3.1:8b) instead
# =============================================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# =============================================================================
# Email / SMTP
# [OPTIONAL] Set MAIL_ENABLED=True to send real appointment reminder emails.
#
# SETUP — Gmail App Password:
#   1. Go to myaccount.google.com → Security
#   2. Enable "2-Step Verification" (required)
#   3. Security → App passwords → Select "Mail" / "Other" → Generate
#   4. Copy the 16-character password into SMTP_PASSWORD below
#   5. Set MAIL_ENABLED=True
# =============================================================================
MAIL_ENABLED=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
FROM_EMAIL=noreply@theraai.dev

# =============================================================================
# Firebase Cloud Messaging (FCM) — Push Notifications
# [OPTIONAL] Set FCM_ENABLED=True after completing setup below.
#
# SETUP:
#   1. Go to console.firebase.google.com → Add project → "TheraAI"
#   2. Project Settings → Service Accounts → "Generate new private key"
#      Save the JSON file as: backend/firebase-service-account.json
#      (This file is gitignored — never commit it)
#   3. Set FCM_ENABLED=True and the path below
#   4. Also fill in the web/.env Firebase config values (for frontend)
# =============================================================================
FCM_ENABLED=False
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json

# =============================================================================
# Google Calendar OAuth2 Sync
# [OPTIONAL] Fill in to enable "Connect Google Calendar" in Settings.
#
# SETUP:
#   1. Go to console.cloud.google.com → Create or select project "TheraAI"
#   2. APIs & Services → Library → search "Google Calendar API" → Enable
#   3. APIs & Services → Credentials → "+ Create Credentials" → OAuth 2.0 Client ID
#   4. Application type: Web application
#   5. Authorized JavaScript origins: http://localhost:3000
#   6. Authorized redirect URIs: http://localhost:8000/api/v1/calendar/callback
#      (For production: https://your-domain.com/api/v1/calendar/callback)
#   7. Copy Client ID and Client Secret below
#   8. APIs & Services → OAuth consent screen → Add test users (your Gmail)
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/calendar/callback

# =============================================================================
# Jitsi Meet — Video Calls
# Default uses the public meet.jit.si server (free, no account needed).
# For a self-hosted Jitsi instance, set JITSI_DOMAIN to your domain.
# =============================================================================
JITSI_DOMAIN=meet.jit.si

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_PERIOD=60

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=DEBUG
LOG_FILE=logs/app.log

# =============================================================================
# File Uploads
# =============================================================================
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/
